  "about": {
    "header": "GAMES MADE WITH PRIDE AND ATTITUDE",
    "description": "Vertebrae Entertainment is founded on fearless art, and a wish to see people like us take center stage in the games we play. Combining the edgy aesthetics and sharp angles of visual artist Hauk Seim Flåøien with the apocalyptic yet empathetic writing of horror author Åge Markus Schultz, we specialize in LGBT centered political games with story at heart.\n Established in 2016 as part of a school project, Vertebrae Entertainment gained nationwide attention for its dedication and focus on delivering queer stories, as well as our ongoing collaborations with equality and diversity minded projects.",
    "people": [
      {
        "name": "Hauk Seim Flåøien",
        "role": "Artist, Game Designer & Writer",
        "image": "assets/people/hauk.webp",
        "description": "Hauk combines 10+ years of graphic design and illustration experience with 8 years of game development, and is on a near-constant hunt to create art so prickly you'll poke yourself on it."
      },
      {
        "name": "Åge Markus Schultz",
        "role": "Writer & Game Programmer",
        "image": "assets/people/Aage.webp",
        "description": "Åge found humble beginnings within the fan game community, and quickly gained notoriety for their unique horror-genre storytelling. Today they are an award-winning writer with 10 years of game design and programming experience."
      }
    ]
  },
